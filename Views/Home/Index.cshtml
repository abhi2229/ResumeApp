@model ResumeApp.Models.ResumeViewModel
@{
    ViewData["Title"] = "Resume";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var nameParts = Model.Profile.Name.Split(' ');
    var firstName = nameParts[0];
    var lastName = nameParts.Length > 1 ? string.Join(" ", nameParts.Skip(1)) : "";
}


 <style media="print">
  @@page {
    size: A4 portrait;
    margin: 0.4in 0.4in;
  }
  @@media print {
    .exp-section {
      page-break-inside: avoid;
    }

    .exp-entry:nth-child(n+4) {
      page-break-before: avoid;
    }

    .projects-section {
      page-break-inside: avoid;
    }

    .proj-card:nth-child(n+3) {
      page-break-before: avoid;
    }
  }
</style>

<div class="shell">

  <!-- ══ SIDEBAR ═══════════════════════════ -->
  <aside class="sidebar">

    <div class="photo-block">
      <img src="image\Profile.jpeg" alt="Abhishek Maiti" />
      <div class="photo-overlay"></div>
      <div class="photo-name">
        <h2><span>@firstName</span> <em>@lastName</em></h2>
        <div class="role-badge">@Model.Profile.Title</div>
      </div>
    </div>

    <div class="sidebar-body">

      <!-- Contact -->
      <div class="s-section">
        <div class="s-label">Contact</div>
        <div class="contact-stack">
          <a class="c-link" href="@Model.Profile.LinkedIn" target="_blank">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          <a class="c-link" href="mailto:@Model.Profile.Email">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            @Model.Profile.Email
          </a>
          <a class="c-link" href="tel:+917602968387">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            @Model.Profile.Phone
          </a>
          <span class="c-link">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            @Model.Profile.Location
          </span>
          <span class="c-link">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-wsidth="1.8"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5z"/></svg>
            Digha, West Bengal
          </span>
        </div>
      </div>

      <div class="s-divider"></div>

      <!-- Core Skills -->
      <div class="s-section">
        <div class="s-label">Core Platform</div>
        <div class="s-skills">
          <div class="skill-bar-item">
            <div class="skill-bar-top"><span class="skill-bar-name">Metrics Module</span></div>
            <div class="skill-bar-track"><div class="skill-bar-fill" data-width="90"></div></div>
          </div>
          <div class="skill-bar-item">
            <div class="skill-bar-top"><span class="skill-bar-name">NABSIC Rules</span></div>
            <div class="skill-bar-track"><div class="skill-bar-fill" data-width="85"></div></div>
          </div>
          <div class="skill-bar-item">
            <div class="skill-bar-top"><span class="skill-bar-name">Shared Functions</span></div>
            <div class="skill-bar-track"><div class="skill-bar-fill" data-width="80"></div></div>
          </div>
          <div class="skill-bar-item">
            <div class="skill-bar-top"><span class="skill-bar-name">Incident Mgmt</span></div>
            <div class="skill-bar-track"><div class="skill-bar-fill" data-width="85"></div></div>
          </div>
          <div class="skill-bar-item">
            <div class="skill-bar-top"><span class="skill-bar-name">Risk Management</span></div>
            <div class="skill-bar-track"><div class="skill-bar-fill" data-width="80"></div></div>
          </div>
        </div>
        <div style="font-family:var(--mono);font-size:0.55rem;color:var(--text-3);margin-top:0.6rem;line-height:1.4;">
          <strong style="color:var(--text-2);">Expertise:</strong> Created multiple Business Analyzer templates in Metrics module for KPI tracking and performance analysis
        </div>
      </div>

      <div class="s-divider"></div>

      <!-- Tools & Platforms -->
      <div class="s-section">
        <div class="s-label">Tools &amp; Platforms</div>
        <div style="font-family:var(--mono);font-size:0.62rem;color:var(--text-2);line-height:1.6;">
          <div style="margin-bottom:0.8rem;">
            <div style="color:var(--text);font-weight:500;margin-bottom:0.2rem;">PROTON ALM</div>
            <div style="font-size:0.58rem;">SYSIQ, APPIQ, OQ, PQ</div>
          </div>
          <div style="margin-bottom:0.8rem;">
            <div style="color:var(--text);font-weight:500;margin-bottom:0.2rem;">ServiceNow (SNOW)</div>
            <div style="font-size:0.58rem;">Ticket creation &amp; maintenance</div>
          </div>
          <div style="margin-bottom:0.8rem;">
            <div style="color:var(--text);font-weight:500;margin-bottom:0.2rem;">Enablon Modules</div>
            <div style="font-size:0.58rem;">Metrics, Incident Mgmt, Risk Mgmt</div>
          </div>
        </div>
      </div>

      <div class="s-divider"></div>

      <!-- Currently learning -->
      <div class="s-section">
        <div class="s-label">Upskilling</div>
        <div class="s-tags">
          <span class="s-tag">Azure</span>
          <span class="s-tag">Angular</span>
          <span class="s-tag">ASP.NET</span>
          <span class="s-tag">C#</span>
          <span class="s-tag">Rest API</span>
        </div>
      </div>

      <div class="s-divider"></div>

      <!-- Education -->
      <div class="s-section">
        <div class="s-label">Education</div>
        <div style="font-family:var(--mono);font-size:0.65rem;color:var(--text-2);line-height:1.8;">
          <div style="color:var(--text);font-size:0.7rem;margin-bottom:0.1rem;">MCA</div>
          <div style="color:var(--text-3)">IEM · 2021–2023</div>
          <div style="margin-top:0.6rem;color:var(--text);font-size:0.7rem;margin-bottom:0.1rem;">BSc Computer Science</div>
          <div style="color:var(--text-3)">Midnapore College · 2018–2021</div>
        </div>
      </div>

    </div>
  </aside>

  <!-- ══ MAIN CONTENT ═══════════════════════ -->
  <main class="main-content" id="main">

    <!-- BIO HEADLINE -->
    <div class="headline-block fade-up">
      <div class="headline-kicker">About</div>
      <blockquote>
       @Model.Profile.Bio
      </blockquote>
     
    </div>

    <!-- EXPERIENCE -->
    <section class="exp-section fade-up" id="experience">
      <div class="sec-head">
        <span class="sec-title">Work Experience</span>
        <div class="sec-line"></div>
      </div>

      @{ int expIdx = 0; }
      @foreach (var exp in Model.Experiences)
      {
        expIdx++;
        <div class="exp-entry">
          <div class="exp-header">
            <div>
              <div class="exp-co">@exp.Company</div>
              <div class="exp-role-title">@exp.Role</div>
            </div>
            <div class="exp-period-badge">@exp.Period</div>
          </div>
          <div class="exp-type-pill">@exp.EmploymentType</div>
          <ul class="exp-bullets">
            @foreach (var b in exp.Bullets)
            {
              <li>@b</li>
            }
          </ul>
        </div>
      }
    </section>

    <!-- SKILLS -->
    <section class="skills-section fade-up" id="skills">
      <div class="sec-head">
        <span class="sec-title">Skills &amp; Technologies</span>
        <div class="sec-line"></div>
      </div>

      <div class="skills-matrix">
        @foreach (var group in Model.SkillGroups)
        {
          <div class="skill-cell">
            <div class="skill-cell-label">@group.Category</div>
            <div class="chip-cloud">
              @foreach (var skill in group.Skills)
              {
                <span class="chip @(skill.IsPrimary ? "hi" : "")">@skill.Name</span>
              }
            </div>
          </div>
        }
      </div>
    </section>

    <!-- PROJECTS -->
    <section class="projects-section fade-up" id="projects">
      <div class="sec-head">
        <span class="sec-title">Projects</span>
        <div class="sec-line"></div>
      </div>

      <div class="projects-list">
        <div class="proj-card">
          <div class="proj-index"><span>01</span></div>
          <div class="proj-body">
            <div class="proj-title">AI-Based Brainstroke Prediction App</div>
            <div class="proj-desc">Developed an intelligent application using Kivy module that predicts brain strokes by implementing multiple machine learning algorithms. The app evaluates different approaches to select the best accurate result for diagnosis.</div>
            <div class="proj-tags">
              <span class="proj-tag">Python</span>
              <span class="proj-tag">Kivy</span>
              <span class="proj-tag">Machine Learning</span>
              <span class="proj-tag">Algorithms</span>
            </div>
          </div>
        </div>

        <div class="proj-card">
          <div class="proj-index"><span>02</span></div>
          <div class="proj-body">
            <div class="proj-title">Intelligent Chatbot with ChatGPT Integration</div>
            <div class="proj-desc">Created a comprehensive chatbot during Cognizant CSD training with dual functionality: Basic mode for telling time, date, weather (via API), and location. Pro mode leverages ChatGPT API for intelligent responses. All conversations stored in MySQL database using ADO.NET.</div>
            <div class="proj-tags">
              <span class="proj-tag">Chatbot</span>
              <span class="proj-tag">ChatGPT API</span>
              <span class="proj-tag">MySQL</span>
              <span class="proj-tag">ADO.NET</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CERTIFICATIONS -->
    <section class="cert-section fade-up">
      <div class="sec-head">
        <span class="sec-title">Certifications</span>
        <div class="sec-line"></div>
      </div>

      <div class="cert-grid">
        @foreach (var cert in Model.Certifications)
        {
          if (!string.IsNullOrEmpty(cert.CertificateUrl))
          {
            <a href="@cert.CertificateUrl" target="_blank" class="cert-card cert-link">
              <div class="cert-icon-box">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div>
                <div class="cert-name">@cert.Name</div>
                <div class="cert-meta">@cert.Issuer · @cert.Year</div>
              </div>
            </a>
          }
          else
          {
            <div class="cert-card">
              <div class="cert-icon-box">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div>
                <div class="cert-name">@cert.Name</div>
                <div class="cert-meta">@cert.Issuer · @cert.Year</div>
              </div>
            </div>
          }
        }
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="main-footer">
      <p>@Model.Profile.Name · Hyderabad (Current) · Digha, West Bengal (Permanent)</p>
      <p><a href="@Model.Profile.LinkedIn" target="_blank">LinkedIn</a> &nbsp;&middot;&nbsp; <a href="#" onclick="window.print();return false;">Print / PDF</a></p>
    </footer>

  </main>
</div>
