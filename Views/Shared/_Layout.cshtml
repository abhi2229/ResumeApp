<!DOCTYPE html>
<html lang="en" id="html-root" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>@ViewData["Title"] — Abhishek Maiti</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true"/>
</head>
<body>

<nav>
  <a class="nav-brand" href="/">AM<span>.</span>resume</a>
  <ul class="nav-links">
    <li><a href="#experience">Experience</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Projects</a></li>
    <li>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme"></button>
    </li>
  </ul>
</nav>

@RenderBody()

<script src="~/js/theme.js" asp-append-version="true"></script>
<script src="~/js/desktop-check.js" asp-append-version="true"></script>

<!-- Desktop Mode Blocker Popup -->
<div id="desktop-blocker" class="hidden">
  <div id="desktop-blocker-box">
    <div id="desktop-blocker-icon">&#128421;</div>
    <h2>Desktop Mode Required</h2>
    <p>This site is optimised for desktop viewing.<br>Please enable <strong>Desktop Mode</strong> in your browser to continue.</p>
    <div id="desktop-blocker-steps">
      <p><strong>Chrome / Android:</strong><br>Tap &#8942; menu &rarr; Check <em>"Desktop site"</em></p>
      <p><strong>Safari / iOS:</strong><br>Tap <span style="font-size:1.1em">&#7424;A</span> in address bar &rarr; <em>"Request Desktop Website"</em></p>
    </div>
    <button id="desktop-blocker-retry">I've enabled it — Retry</button>
  </div>
</div>

<style>
#desktop-blocker {
  position: fixed;
  inset: 0;
  z-index: 99999;
  background: rgba(0,0,0,0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  padding: 20px;
}
#desktop-blocker.hidden { display: none !important; }
#desktop-blocker-box {
  background: #111;
  border: 1px solid #2e2e2e;
  border-radius: 16px;
  padding: 36px 28px;
  max-width: 360px;
  width: 100%;
  text-align: center;
  color: #eee;
  font-family: 'Outfit', sans-serif;
  box-shadow: 0 8px 40px rgba(0,0,0,0.6);
}
#desktop-blocker-icon { font-size: 3rem; margin-bottom: 12px; }
#desktop-blocker-box h2 { font-size: 1.3rem; font-weight: 600; margin: 0 0 10px; color: #fff; }
#desktop-blocker-box > p { font-size: 0.9rem; color: #aaa; line-height: 1.6; margin: 0 0 16px; }
#desktop-blocker-steps { background: #1a1a1a; border-radius: 10px; padding: 14px 16px; margin-bottom: 20px; text-align: left; }
#desktop-blocker-steps p { margin: 0 0 10px; font-size: 0.82rem; color: #bbb; line-height: 1.5; }
#desktop-blocker-steps p:last-child { margin-bottom: 0; }
#desktop-blocker-steps strong { color: #fff; }
#desktop-blocker-steps em { color: #ddd; }
#desktop-blocker-retry {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 8px;
  padding: 12px 28px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  width: 100%;
  font-family: 'Outfit', sans-serif;
  transition: background 0.2s;
}
#desktop-blocker-retry:hover { background: #ddd; }
</style>

</body>
</html>
