<!DOCTYPE html>
<html lang="en" id="html-root" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>@ViewData["Title"] — Abhishek Maiti</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true"/>

<!-- Inline mobile blocker styles - runs immediately -->
<style>
@@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

html.mobile-detected {
  overflow: hidden;
}

html.mobile-detected body {
  overflow: hidden;
  background: #000;
}

html.mobile-detected nav,
html.mobile-detected main,
html.mobile-detected footer {
  display: none !important;
}

html.mobile-detected #mobile-blocker-overlay {
  display: flex !important;
  opacity: 1 !important;
  animation: fadeIn 0.4s ease-out forwards;
}

#mobile-blocker-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 999999;
  background: linear-gradient(135deg, rgba(10, 10, 10, 0.98) 0%, rgba(20, 20, 20, 0.98) 100%);
  align-items: center;
  justify-content: center;
  padding: 20px;
  font-family: 'Outfit', sans-serif;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}

#mobile-blocker-content {
  background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 100%);
  border: 1px solid #333;
  border-radius: 20px;
  padding: 48px 32px;
  max-width: 420px;
  width: 100%;
  text-align: center;
  color: #eee;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

#mobile-blocker-icon {
  font-size: 4rem;
  margin-bottom: 20px;
  display: inline-block;
  animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s forwards;
  opacity: 0;
}

#mobile-blocker-content h2 {
  font-size: 1.6rem;
  font-weight: 700;
  margin: 0 0 12px;
  color: #fff;
  letter-spacing: -0.5px;
}

#mobile-blocker-content > p {
  font-size: 1rem;
  color: #aaa;
  line-height: 1.8;
  margin: 0 0 24px;
}

#mobile-blocker-content > p strong {
  color: #fff;
  font-weight: 600;
}

#mobile-blocker-instructions {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 28px;
  text-align: left;
  backdrop-filter: blur(4px);
}

#mobile-blocker-instructions p {
  margin: 0 0 14px;
  font-size: 0.9rem;
  color: #bbb;
  line-height: 1.7;
}

#mobile-blocker-instructions p:last-child {
  margin-bottom: 0;
}

#mobile-blocker-instructions strong {
  color: #fff;
  font-weight: 600;
  display: block;
  margin-bottom: 4px;
}

#mobile-blocker-instructions em {
  color: #e8e8e8;
  font-style: normal;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.08);
  padding: 2px 6px;
  border-radius: 4px;
  display: inline-block;
}

#mobile-blocker-retry {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  color: #000;
  border: none;
  border-radius: 10px;
  padding: 14px 40px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  width: 100%;
  font-family: 'Outfit', sans-serif;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 8px 24px rgba(255, 255, 255, 0.15);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

#mobile-blocker-retry:active {
  background: linear-gradient(135deg, #f0f0f0 0%, #e5e5e5 100%);
  transform: scale(0.98);
}

#mobile-blocker-retry:hover {
  background: linear-gradient(135deg, #fff 0%, #fff 100%);
  box-shadow: 0 12px 32px rgba(255, 255, 255, 0.2);
}
</style>

<!-- Inline mobile detection - runs BEFORE page renders -->
<script>
(function() {
  function isRealMobileDevice() {
    var ua = navigator.userAgent.toLowerCase();
    // Comprehensive mobile detection
    var isMobileUA = /android|webos|iphone|ipad|ipod|blackberry|iemobile|opera mini|silk|windows phone|mobile|tablet/.test(ua);
    var hasTouchScreen = (('ontouchstart' in window) || (navigator.maxTouchPoints > 0) || (navigator.msMaxTouchPoints > 0));
    var isNarrowScreen = window.innerWidth < 1024;
    var isSmallHeight = window.innerHeight < 700;

    // If it's a mobile UA with touch OR small screen, block it
    return isMobileUA && (hasTouchScreen || isNarrowScreen || isSmallHeight);
  }

  if (isRealMobileDevice()) {
    document.documentElement.classList.add('mobile-detected');
  }
})();
</script>
</head>
<body>

<!-- Mobile Blocker Overlay -->
<div id="mobile-blocker-overlay">
  <div id="mobile-blocker-content">
    <div id="mobile-blocker-icon">📱</div>
    <h2>Desktop View Required</h2>
    <p>This resume is optimized for desktop experience.<br>Please enable <strong>Desktop Mode</strong> to continue.</p>
    <div id="mobile-blocker-instructions">
      <p><strong>Chrome on Android:</strong><br>Tap ⋮ (menu) → Enable <em>"Desktop site"</em></p>
      <p><strong>Safari on iOS:</strong><br>Tap <em>aA</em> (share icon) in address bar → <em>"Request Desktop Website"</em></p>
    </div>
    <button id="mobile-blocker-retry">✓ I've Enabled It - Check Again</button>
  </div>
</div>

<nav>
  <a class="nav-brand" href="/">AM<span>.</span>resume</a>
  <ul class="nav-links">
    <li><a href="#experience">Experience</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Projects</a></li>
    <li>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme"></button>
    </li>
  </ul>
</nav>

@RenderBody()

<script src="~/js/theme.js" asp-append-version="true"></script>
<script src="~/js/mobile-check.js" asp-append-version="true"></script>

</body>
</html>
