<!DOCTYPE html>
<html lang="en" id="html-root" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>@ViewData["Title"] — Abhishek Maiti</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
<link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true"/>

<!-- Inline mobile blocker styles - runs immediately -->
<style>
html.mobile-detected body { display: none; }
html.mobile-detected #mobile-blocker-overlay { display: flex !important; }
#mobile-blocker-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 999999;
  background: rgba(0,0,0,0.98);
  align-items: center;
  justify-content: center;
  padding: 20px;
  font-family: 'Outfit', sans-serif;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
#mobile-blocker-content {
  background: #111;
  border: 1px solid #2e2e2e;
  border-radius: 16px;
  padding: 40px 28px;
  max-width: 380px;
  width: 100%;
  text-align: center;
  color: #eee;
  box-shadow: 0 8px 40px rgba(0,0,0,0.8);
}
#mobile-blocker-icon { font-size: 3.5rem; margin-bottom: 16px; }
#mobile-blocker-content h2 { font-size: 1.4rem; font-weight: 700; margin: 0 0 12px; color: #fff; }
#mobile-blocker-content > p { font-size: 0.95rem; color: #aaa; line-height: 1.7; margin: 0 0 20px; }
#mobile-blocker-instructions { background: #1a1a1a; border-radius: 10px; padding: 16px; margin-bottom: 24px; text-align: left; }
#mobile-blocker-instructions p { margin: 0 0 12px; font-size: 0.85rem; color: #bbb; line-height: 1.6; }
#mobile-blocker-instructions p:last-child { margin-bottom: 0; }
#mobile-blocker-instructions strong { color: #fff; font-weight: 600; }
#mobile-blocker-instructions em { color: #e0e0e0; font-style: normal; font-weight: 500; }
#mobile-blocker-retry {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 8px;
  padding: 13px 32px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  width: 100%;
  font-family: 'Outfit', sans-serif;
  transition: all 0.2s;
}
#mobile-blocker-retry:active { background: #ccc; }
</style>

<!-- Inline mobile detection - runs BEFORE page renders -->
<script>
(function() {
  function isRealMobileDevice() {
    var ua = navigator.userAgent;
    // More comprehensive mobile detection
    var isMobileUA = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Silk|Windows Phone|Mobile|Tablet/i.test(ua);
    var hasTouchScreen = (('ontouchstart' in window) || (navigator.maxTouchPoints > 0) || (navigator.msMaxTouchPoints > 0));
    var isNarrowScreen = window.innerWidth < 1024;
    var isSmallHeight = window.innerHeight < 700;

    // Debug log (remove in production)
    console.log('Mobile detection - UA:', isMobileUA, 'Touch:', hasTouchScreen, 'Narrow:', isNarrowScreen, 'SmallHeight:', isSmallHeight);

    // If it's a mobile UA with touch OR small screen, block it
    return isMobileUA && (hasTouchScreen || isNarrowScreen || isSmallHeight);
  }

  if (isRealMobileDevice()) {
    document.documentElement.classList.add('mobile-detected');
  }
})();
</script>
</head>
<body>

<!-- Mobile Blocker Overlay -->
<div id="mobile-blocker-overlay">
  <div id="mobile-blocker-content">
    <div id="mobile-blocker-icon">📱</div>
    <h2>Desktop Only</h2>
    <p>This site is optimised for desktop viewing.<br>Please access it from a desktop or enable <strong>Desktop Mode</strong>.</p>
    <div id="mobile-blocker-instructions">
      <p><strong>Chrome / Android:</strong><br>Tap <em>⋮</em> menu → Check <em>"Desktop site"</em></p>
      <p><strong>Safari / iOS:</strong><br>Tap <em>aA</em> in address bar → <em>"Request Desktop Website"</em></p>
    </div>
    <button id="mobile-blocker-retry">Check Again</button>
  </div>
</div>

<nav>
  <a class="nav-brand" href="/">AM<span>.</span>resume</a>
  <ul class="nav-links">
    <li><a href="#experience">Experience</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Projects</a></li>
    <li>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme"></button>
    </li>
  </ul>
</nav>

@RenderBody()

<script src="~/js/theme.js" asp-append-version="true"></script>
<script src="~/js/mobile-check.js" asp-append-version="true"></script>

</body>
</html>
